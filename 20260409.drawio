        <mxCell id="3KsziyiJGjYwYtRfmXxj-61" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=26;fontStyle=1;fontColor=#1f1f1f;" value="从四个研究方向到第三章、第四章主方法确定的收敛过程" vertex="1">
          <mxGeometry height="40" width="1460" x="440.0000244140625" y="1380" as="geometry" />
        </mxCell>
        <mxCell id="3KsziyiJGjYwYtRfmXxj-62" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" value="内容可信度、知识/目标对齐、证据归因、评价可靠性&lt;br&gt;目标：明确第三章做什么、第四章做什么，以及两章如何递进衔接" vertex="1">
          <mxGeometry height="80" width="464" x="938.0000000000001" y="1440" as="geometry" />
        </mxCell>
        <mxCell id="3KsziyiJGjYwYtRfmXxj-63" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;align=center;spacingLeft=12;" value="先设定筛选约束&lt;br&gt;1. 第三章必须为第四章提供基础，不能并列平铺&lt;br&gt;2. 论文重心必须是方法问题，而不是应用场景描述&lt;br&gt;3. 每一章都要解决一个具体局限，边界不能重叠" vertex="1">
          <mxGeometry height="95" width="470" x="935.6" y="1550" as="geometry" />
        </mxCell>
        <mxCell id="3KsziyiJGjYwYtRfmXxj-64" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;" value="第一轮：判断每个方向在整篇论文中适合扮演什么角色" vertex="1">
          <mxGeometry height="60" width="650" x="845.6" y="1685" as="geometry" />
        </mxCell>
        <mxCell id="3KsziyiJGjYwYtRfmXxj-65" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;" value="方向一：内容可信度&#xa;关注生成内容是否真实、是否减少幻觉、是否可验证纠错" vertex="1">
          <mxGeometry height="95" width="358.4" x="340.6" y="1800" as="geometry" />
        </mxCell>
        <mxCell id="3KsziyiJGjYwYtRfmXxj-66" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;" value="方向二：知识 / 目标对齐&#xa;关注说什么、怎么组织、是否偏离任务目标" vertex="1">
          <mxGeometry height="95" width="272.4" x="744.6" y="1800" as="geometry" />
        </mxCell>
        <mxCell id="3KsziyiJGjYwYtRfmXxj-67" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;" value="方向三：证据归因&#xa;关注 claim 与 evidence 能否显式绑定、是否便于核验" vertex="1">
          <mxGeometry height="95" width="342.4" x="1087.6" y="1800" as="geometry" />
        </mxCell>
        <mxCell id="3KsziyiJGjYwYtRfmXxj-68" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;" value="方向四：评价可靠性&#xa;关注评测是否稳定、可复核、与人评是否一致" vertex="1">
          <mxGeometry height="95" width="292.4" x="1497.6" y="1800" as="geometry" />
        </mxCell>
        <mxCell id="3KsziyiJGjYwYtRfmXxj-69" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=14;" value="第二轮：在“章节必须递进”的约束下，哪条主线最顺？" vertex="1">
          <mxGeometry height="130" width="360" x="805.0000244140625" y="1950" as="geometry" />
        </mxCell>
        <mxCell id="3KsziyiJGjYwYtRfmXxj-70" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" value="知识 / 目标对齐不作为独立主章&#xa;原因：概念容易发散，且与证据组织、规划模块边界重叠&#xa;最终处理：退为第三章中的支撑模块" vertex="1">
          <mxGeometry height="110" width="430" x="80.00002441406252" y="2120" as="geometry" />
        </mxCell>
        <mxCell id="3KsziyiJGjYwYtRfmXxj-71" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" value="保留的主线：证据归因 → 内容可信度&lt;br&gt;原因：先构建可核验结构，再在该结构上做可信度评估与优化，逻辑最干净，章节边界也最清楚" vertex="1">
          <mxGeometry height="95" width="510" x="730.6" y="2115" as="geometry" />
        </mxCell>
        <mxCell id="3KsziyiJGjYwYtRfmXxj-72" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" value="评价可靠性不作为独立主章&#xa;原因：更像元评测，容易把论文重心带偏&#xa;最终处理：作为第三章、第四章共同的实验协议与约束条件" vertex="1">
          <mxGeometry height="110" width="430" x="1470.0000244140624" y="2120" as="geometry" />
        </mxCell>
        <mxCell id="3KsziyiJGjYwYtRfmXxj-73" parent="1" style="swimlane;html=1;rounded=1;startSize=52;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;" value="第三章问题锁定&#xa;在‘证据归因’问题簇内部继续收缩" vertex="1">
          <mxGeometry height="550" width="890" x="50.00002441406252" y="2300" as="geometry" />
        </mxCell>

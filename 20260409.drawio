          <mxGeometry height="90" width="130" x="77.6" y="60" as="geometry" />
        </mxCell>
        <mxCell id="3KsziyiJGjYwYtRfmXxj-75" parent="3KsziyiJGjYwYtRfmXxj-73" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=13;" value="候选 2&#xa;查询式局部归因接口&#xa;代表：LAQuer" vertex="1">
          <mxGeometry height="90" width="170" x="347.6" y="60" as="geometry" />
        </mxCell>
        <mxCell id="3KsziyiJGjYwYtRfmXxj-76" parent="3KsziyiJGjYwYtRfmXxj-73" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=13;" value="候选 3&#xa;生成期细粒度归因结构&#xa;代表：Attribute First、ReClaim" vertex="1">
          <mxGeometry height="90" width="210" x="627.6" y="60" as="geometry" />
        </mxCell>
        <mxCell id="3KsziyiJGjYwYtRfmXxj-77" parent="3KsziyiJGjYwYtRfmXxj-73" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=13;" value="第三章最适合锁定哪一类问题？" vertex="1">
          <mxGeometry height="120" width="290" x="300" y="190" as="geometry" />
        </mxCell>
        <mxCell id="3KsziyiJGjYwYtRfmXxj-78" parent="3KsziyiJGjYwYtRfmXxj-73" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" value="第三章问题锁定结果&#xa;优先选择‘生成期细粒度证据归因结构’&#xa;原因：它直接产出可核验中间结构，并且不会把修订、保留性和可信度判断揉在一起" vertex="1">
          <mxGeometry height="85" width="530" x="180" y="345" as="geometry" />
        </mxCell>

        <mxCell id="dejLF14Mv_5d38B0jCep-58" parent="1" style="text;whiteSpace=wrap;html=1;fillColor=none;fontColor=default;labelBackgroundColor=none;" value="&lt;ul style=&quot;forced-color-adjust: none; font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; margin: 0px; padding-left: 24px;&quot;&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;已建立柑橘苗木微波热处理三维模型&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;已完成电磁-热耦合仿真模型验证&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;已反演叶片、枝干介电参数&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;已筛选最优腔体结构：球体腔体+4个磁控管+侧面均匀分布&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;已证明150–450 W范围内模型可靠&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="100" width="275" x="582.5" y="260" as="geometry" />
        </mxCell>
        <mxCell id="dejLF14Mv_5d38B0jCep-59" parent="1" style="text;whiteSpace=wrap;html=1;labelBackgroundColor=none;" value="&lt;ul style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; margin: 0px; padding-left: 24px;&quot;&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;b style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;在既有优选结构条件下，微波功率、转盘转速和加热时间如何协同作用于低损伤热处理效果？&lt;/font&gt;&lt;/b&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;b style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;如何筛选兼顾升温效率、温度均匀性与热损伤控制的适宜参数组合？&lt;/font&gt;&lt;/b&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;b style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;不同参数组合影响局部过热与热损伤形成的电磁-热作用机制是什么？&lt;/font&gt;&lt;/b&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="70" width="305" x="892" y="263" as="geometry" />
        </mxCell>
        <mxCell id="dejLF14Mv_5d38B0jCep-60" parent="1" style="text;whiteSpace=wrap;html=1;labelBackgroundColor=none;" value="&lt;ul style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; margin: 0px; padding-left: 24px;&quot;&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;前期研究已回答“优选结构为何更适用”这一结构层面问题&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;但尚缺乏在优选结构条件下对关键工艺参数协同作用的系统研究&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;参数组合优化与低损伤热处理效果之间的机制联系仍不够清晰&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;尚未形成面向现有设备条件的参数建议与适用边界分析&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="100" width="351" x="1228" y="260" as="geometry" />
        </mxCell>
        <mxCell id="dejLF14Mv_5d38B0jCep-61" parent="1" style="text;whiteSpace=wrap;html=1;labelBackgroundColor=none;" value="&lt;ul style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; margin: 0px; padding-left: 24px;&quot;&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;明确微波功率、转盘转速和加热时间对温度均匀性及热损伤风险的影响规律&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;采用单因素分析与正交试验筛选适宜参数组合&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;基于电场分布、吸收功率密度和温度热点演化解释参数组合差异&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;形成面向现有设备条件的参数建议&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="65" width="355" x="643" y="424" as="geometry" />
        </mxCell>
        <mxCell id="dejLF14Mv_5d38B0jCep-62" parent="1" style="text;whiteSpace=wrap;html=1;labelBackgroundColor=none;" value="&lt;ul style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; margin: 0px; padding-left: 24px;&quot;&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;研究对象限定于前期优选结构：球体腔体 + 4个磁控管 + 侧面均匀分布&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;功率范围限定为前期已验证的150–450 W&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;研究变量聚焦于微波功率、转盘转速和加热时间&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;不再开展大范围腔体结构重筛选&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;不涉及动态介电常数、相位控制及复杂硬件改造&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="100" width="349" x="1052" y="425" as="geometry" />
        </mxCell>
        <mxCell id="dejLF14Mv_5d38B0jCep-63" parent="1" style="text;whiteSpace=wrap;html=1;labelBackgroundColor=none;" value="&lt;ul style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; margin: 0px; padding-left: 20px;&quot;&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;继承前期已验证三维模型、介电参数和电磁-热耦合框架&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;固定优选结构作为基线结构&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;明确研究功率范围与关键参数边界&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;建立参数分析与结果后处理流程&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="90" width="190" x="570" y="595" as="geometry" />
        </mxCell>
        <mxCell id="dejLF14Mv_5d38B0jCep-64" parent="1" style="text;whiteSpace=wrap;html=1;labelBackgroundColor=none;" value="&lt;ul style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; margin: 0px; padding-left: 20px;&quot;&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;以微波功率、转盘转速和加热时间为研究因素&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;分析不同参数变化对温度场分布和温度均匀性的影响&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;比较温度标准差、温度变异系数、最大温差和热损伤风险&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;明确各因素作用趋势与合理水平范围&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="52.5" width="193" x="779" y="590" as="geometry" />
        </mxCell>
        <mxCell id="dejLF14Mv_5d38B0jCep-65" parent="1" style="text;whiteSpace=wrap;html=1;labelBackgroundColor=none;" value="&lt;ul style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; margin: 0px; padding-left: 20px;&quot;&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;构建三因素三水平正交试验方案&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;系统比较不同参数组合下的升温行为、温度均匀性和热损伤风险&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;采用综合评分、极差分析和方差分析评价参数组合&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;筛选适宜的低损伤微波热处理参数组合&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="70" width="214" x="1008" y="598" as="geometry" />
        </mxCell>
        <mxCell id="dejLF14Mv_5d38B0jCep-66" parent="1" style="text;whiteSpace=wrap;html=1;labelBackgroundColor=none;" value="&lt;ul style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; margin: 0px; padding-left: 20px;&quot;&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;span style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;从较优、居中和较差参数组合中选取代表性工况&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none;&quot;&gt;&lt;span style=&quot;forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;对关键测点温度进行对比分析&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;font-weight: 400; forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;对参数优化结果的合理性和代表性进行验证支撑&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;font-weight: 400; forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 13px;&quot;&gt;形成综合评价结论&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">

        <mxCell id="label5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2B5079;strokeColor=none;fontColor=#ffffff;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;" value="实验验证与&lt;br&gt;结果分析" vertex="1">
          <mxGeometry height="190" width="130" x="20" y="670" as="geometry" />
        </mxCell>
        <mxCell id="L1_H1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#366092;strokeColor=none;fontColor=#ffffff;fontSize=14;fontStyle=1;align=center;arcSize=20;" value="前期研究基础" vertex="1">
          <mxGeometry height="30" width="360" x="170" y="80" as="geometry" />
        </mxCell>
        <mxCell id="L1_B1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF1F8;strokeColor=#366092;fontColor=#000000;fontSize=12;align=left;verticalAlign=top;spacingTop=5;spacingLeft=10;spacingRight=10;arcSize=12;" value="&lt;ul style=&quot;margin:0px;padding-left:24px;&quot;&gt;&lt;li&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;已建立柑橘苗木微波热处理三维模型&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;已完成电磁-热耦合仿真模型验证&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;已反演叶片、枝干介电参数&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;已筛选最优腔体结构：球体腔体+4个磁控管+侧面均匀分布&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;已证明150–450 W范围内模型可靠&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="110" width="360" x="170" y="110" as="geometry" />
        </mxCell>
        <mxCell id="L1_H2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#366092;strokeColor=none;fontColor=#ffffff;fontSize=14;fontStyle=1;align=center;arcSize=20;" value="核心科学问题" vertex="1">
          <mxGeometry height="30" width="350" x="560" y="80" as="geometry" />
        </mxCell>
        <mxCell id="L1_B2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF1F8;strokeColor=#366092;fontColor=#000000;fontSize=12;align=left;verticalAlign=top;spacingTop=5;spacingLeft=10;spacingRight=10;" value="&lt;ul style=&quot;margin:0px;padding-left:24px;&quot;&gt;&lt;li&gt;&lt;b&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;电磁场不均如何演化为局部热点与热损伤？&lt;/font&gt;&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;驻波在最优腔体中如何形成与分布？&lt;/font&gt;&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;如何在不改变总体最优结构前提下进一步抑制驻波、降低热损伤？&lt;/font&gt;&lt;/b&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="110" width="350" x="560" y="110" as="geometry" />
        </mxCell>
        <mxCell id="L1_H3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#366092;strokeColor=none;fontColor=#ffffff;fontSize=14;fontStyle=1;align=center;arcSize=20;" value="现有不足" vertex="1">
          <mxGeometry height="30" width="360" x="940" y="80" as="geometry" />
        </mxCell>
        <mxCell id="L1_B3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF1F8;strokeColor=#366092;fontColor=#000000;fontSize=12;align=left;verticalAlign=top;spacingTop=5;spacingLeft=10;spacingRight=10;" value="&lt;ul style=&quot;margin:0px;padding-left:24px;&quot;&gt;&lt;li&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;已回答“哪种结构更优”&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;尚未系统揭示电磁场分布规律&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;尚未明确驻波形成与热点迁移机制&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;尚未建立电磁场指标与热损伤之间的定量联系&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;尚缺少面向现有装置的驻波抑制方案&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="110" width="360" x="940" y="110" as="geometry" />
        </mxCell>
        <mxCell id="L2_H1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#366092;strokeColor=none;fontColor=#ffffff;fontSize=14;fontStyle=1;align=center;arcSize=20;" value="研究目标" vertex="1">
          <mxGeometry height="30" width="500" x="170" y="240" as="geometry" />
        </mxCell>
        <mxCell id="L2_B1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF1F8;strokeColor=#366092;fontColor=#000000;fontSize=12;align=left;verticalAlign=top;spacingTop=5;spacingLeft=10;spacingRight=10;" value="&lt;ul style=&quot;margin:0px;padding-left:24px;&quot;&gt;&lt;li&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;构建微波腔体电磁场评价指标体系&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;揭示电场热点—吸收功率密度热点—温度热点的传递关系&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;解析驻波形成机理及其对温度均匀性的影响&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;提出可实施的驻波抑制策略&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;为柑橘苗木低损伤微波热处理设备优化提供依据&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="100" width="500" x="170" y="270" as="geometry" />
        </mxCell>
        <mxCell id="L2_H2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C00000;strokeColor=none;fontColor=#ffffff;fontSize=14;fontStyle=1;align=center;arcSize=20;" value="研究边界" vertex="1">
          <mxGeometry height="30" width="600" x="700" y="240" as="geometry" />
        </mxCell>
        <mxCell id="L2_B2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAECEC;strokeColor=#C00000;strokeWidth=2;fontColor=#000000;fontSize=12;align=left;verticalAlign=top;spacingTop=5;spacingLeft=10;spacingRight=10;" value="&lt;ul style=&quot;margin:0px;padding-left:24px;&quot;&gt;&lt;li&gt;仅研究150–450 W已验证功率范围&lt;/li&gt;&lt;li&gt;以“球体腔体 + 4个磁控管 + 侧面均匀分布”为基线结构&lt;/li&gt;&lt;li&gt;&lt;b style=&quot;color:#C00000;font-size:13px;&quot;&gt;重点变量仅限：波导口耦合方向、转盘速度&lt;/b&gt;&lt;/li&gt;&lt;li&gt;不展开高功率非线性问题 / 不展开动态介电参数&lt;/li&gt;&lt;li&gt;不展开细观组织异质性建模 / 不展开磁控管相位控制和大规模硬件改造&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="100" width="600" x="700" y="270" as="geometry" />
        </mxCell>
        <mxCell id="L3_H1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#366092;strokeColor=none;fontColor=#ffffff;fontSize=14;align=center;arcSize=15;" value="&lt;b&gt;研究内容一&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;font-weight:normal;&quot;&gt;基线模型继承与电磁场后处理建立&lt;/span&gt;" vertex="1">
          <mxGeometry height="45" width="210" x="170" y="390" as="geometry" />
        </mxCell>
        <mxCell id="L3_B1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF1F8;strokeColor=#366092;fontColor=#000000;fontSize=12;align=left;verticalAlign=top;spacingTop=5;spacingLeft=5;spacingRight=5;glass=0;shadow=0;" value="&lt;ul style=&quot;margin:0px;padding-left:20px;&quot;&gt;&lt;li&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;继承前期已验证三维模型与材料参数&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;保持最优腔体结构为基线&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;构建适用于电磁场分析的后处理流程&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;提取电场强度、吸收功率密度等空间分布信息&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">

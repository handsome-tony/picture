        <mxCell id="cdKcDxsXoZ0XK-X5CE99-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" value="内容可信度、知识/目标对齐、证据归因、评价可靠性&lt;br&gt;目标：明确第三章做什么、第四章做什么，以及两章如何递进衔接" vertex="1">
          <mxGeometry height="80" width="464" x="1332.4" y="280" as="geometry" />
        </mxCell>
        <mxCell id="cdKcDxsXoZ0XK-X5CE99-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;align=center;spacingLeft=12;" value="先设定筛选约束&lt;br&gt;1. 第三章必须为第四章提供基础，不能并列平铺&lt;br&gt;2. 论文重心必须是方法问题，而不是应用场景描述&lt;br&gt;3. 每一章都要解决一个具体局限，边界不能重叠" vertex="1">
          <mxGeometry height="95" width="470" x="1330" y="390" as="geometry" />
        </mxCell>
        <mxCell id="cdKcDxsXoZ0XK-X5CE99-4" edge="1" parent="1" source="cdKcDxsXoZ0XK-X5CE99-1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;jettySize=auto;html=1;" target="cdKcDxsXoZ0XK-X5CE99-2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cdKcDxsXoZ0XK-X5CE99-6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#6c8ebf;fontSize=15;" value="第一轮：判断每个方向在整篇论文中适合扮演什么角色" vertex="1">
          <mxGeometry height="60" width="440" x="1340" y="520" as="geometry" />
        </mxCell>
        <mxCell id="cdKcDxsXoZ0XK-X5CE99-7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#b85450;fontSize=14;" value="方向一：内容可信度&#xa;关注生成内容是否真实、是否减少幻觉、是否可验证纠错" vertex="1">
          <mxGeometry height="95" width="219" x="1070" y="635" as="geometry" />
        </mxCell>
        <mxCell id="cdKcDxsXoZ0XK-X5CE99-8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82b366;fontSize=14;" value="方向二：知识 / 目标对齐&#xa;关注说什么、怎么组织、是否偏离任务目标" vertex="1">
          <mxGeometry height="95" width="207" x="1330" y="635" as="geometry" />
        </mxCell>
        <mxCell id="cdKcDxsXoZ0XK-X5CE99-9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#6c8ebf;fontSize=14;" value="方向三：证据归因&#xa;关注 claim 与 evidence 能否显式绑定、是否便于核验" vertex="1">
          <mxGeometry height="95" width="210" x="1586.4" y="635" as="geometry" />
        </mxCell>
        <mxCell id="cdKcDxsXoZ0XK-X5CE99-10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#9673a6;fontSize=14;" value="方向四：评价可靠性&#xa;关注评测是否稳定、可复核、与人评是否一致" vertex="1">
          <mxGeometry height="95" width="190" x="1840" y="635" as="geometry" />
        </mxCell>
        <mxCell id="cdKcDxsXoZ0XK-X5CE99-11" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=14;" value="第二轮：在“章节必须递进”的约束下，哪条主线最顺？" vertex="1">
          <mxGeometry height="130" width="360" x="1375" y="785" as="geometry" />
        </mxCell>
        <mxCell id="cdKcDxsXoZ0XK-X5CE99-12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#82b366;fontSize=13;" value="“知识 / 目标对齐”更像一个前置能力层，它更适合内化成第三章中的证据组织、子图选择、段落规划模块，而不是单独占据第三章主问题。" vertex="1">
          <mxGeometry height="92.5" width="240" x="1040" y="947.5" as="geometry" />
        </mxCell>
        <mxCell id="cdKcDxsXoZ0XK-X5CE99-13" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" value="保留的主线：证据归因 → 内容可信度&lt;br&gt;原因：先构建可核验结构，再在该结构上做可信度评估与优化，逻辑最干净，章节边界也最清楚" vertex="1">
          <mxGeometry height="95" width="320" x="1395" y="955" as="geometry" />
        </mxCell>
        <mxCell id="cdKcDxsXoZ0XK-X5CE99-14" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#9673a6;fontSize=13;" value="评价可靠性不作为独立主章&#xa;原因：更像元评测，容易把论文重心带偏&#xa;最终处理：作为第三章、第四章共同的实验协议与约束条件" vertex="1">
          <mxGeometry height="110" width="260" x="1842" y="955" as="geometry" />
        </mxCell>
        <mxCell id="cdKcDxsXoZ0XK-X5CE99-43" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;align=center;spacingLeft=12;" value="两章需要通过接口变量连接起来&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="405" x="1372.5" y="1890" as="geometry" />
        </mxCell>
